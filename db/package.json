{
  "name": "@reelify/db",
  "version": "0.0.0",
  "private": true,
  "description": "Reelify database schema + versioned migrations (Prisma).",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "validate": "prisma validate --schema schema.prisma",
    "format": "prisma format --schema schema.prisma",
    "generate": "prisma generate --schema schema.prisma",
    "migrate:dev": "prisma migrate dev --schema schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema schema.prisma",
    "migrate:status": "prisma migrate status --schema schema.prisma"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  }
}
