# Control-plane API (see the frontend integration guide for the full contract)
NEXT_PUBLIC_API_BASE=https://api.reelify.cc

# Amazon Cognito (pilot pool — these are public client identifiers, not secrets)
NEXT_PUBLIC_COGNITO_REGION=us-east-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_8EcTmjQmQ
NEXT_PUBLIC_COGNITO_CLIENT_ID=2kq0sp03kcp58tphi7e64iqf0t
NEXT_PUBLIC_COGNITO_HOSTED_UI_DOMAIN=reelify-auth.auth.us-east-1.amazoncognito.com

# This app's own base URL, used to build the Cognito Hosted UI redirect_uri.
# NOTE: must be registered as an allowed callback URL on the Cognito app
# client (us-east-1_8EcTmjQmQ / 2kq0sp03kcp58tphi7e64iqf0t) — the pilot config
# currently only registers /en/app-shaped callbacks, so /auth/callback needs
# to be added there before Google sign-in will round-trip. See plan's
# "Flagged infra follow-ups".
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Single pilot workspace every real API call is scoped to for now.
NEXT_PUBLIC_PILOT_WORKSPACE_ID=ws_e2e
