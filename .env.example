# ===========================================
# Reelify Environment Variables (PLACEHOLDERS ONLY)
# ===========================================
# Copy this file to .env.local and fill in your values.
# NEVER commit real secrets. Production secrets live in AWS Secrets Manager + KMS
# and are injected into ECS tasks via task-role-scoped secret references.

# ===========================================
# AI Services
# ===========================================
# ElevenLabs API for transcription (Scribe v2)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
# Multiple keys (comma-separated) – legacy client-side rotation. In the new
# pipeline the transcription worker resolves keys from Secrets Manager.
ELEVENLABS_API_KEYS=your_key_1,your_key_2,your_key_3

# Google Gemini for clip scoring
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-pro

# ===========================================
# YouTube OAuth (Google Cloud Console)
# ===========================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===========================================
# Facebook OAuth (Meta for Developers)
# ===========================================
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# ===========================================
# Application Settings
# ===========================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ===========================================
# Axiom Monitoring (Optional / legacy)
# ===========================================
AXIOM_TOKEN=your_axiom_token
AXIOM_ORG_ID=your_axiom_org_id

# ===========================================
# Supabase (legacy credit system — retired during AWS migration)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_service_role_key

# ===========================================
# PostHog Analytics
# ===========================================
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_EXCLUDED_USER_IDS=

# ===========================================
# Sentry
# ===========================================
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project

# ===========================================
# AWS Migration (target architecture) — Phase 1
# ===========================================
# Primary AWS region + tenant data plane. agencies.data_region is immutable.
AWS_REGION=us-east-1
DEFAULT_DATA_REGION=us

# S3 media bucket is resolved SERVER-SIDE from agencies.data_region. This is the
# bucket name for the "us" data plane (output of the Terraform storage module).
MEDIA_BUCKET_US=reelify-media-us-dev

# RDS PostgreSQL (via RDS Proxy). Do not put the real password here — pulled from
# Secrets Manager in deployed environments.
DATABASE_URL=postgresql://reelify:password@localhost:5432/reelify?schema=public

# SQS queue URLs (outputs of the Terraform queue module)
SQS_TRANSCRIPTION_QUEUE_URL=
SQS_SCORING_QUEUE_URL=
SQS_EXTRACTION_QUEUE_URL=

# KMS key id used for SSE-KMS on media + secrets (output of Terraform)
KMS_KEY_ID=

# ===========================================
# Identity — Amazon Cognito (chosen IdP)
# ===========================================
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_DOMAIN=
COGNITO_REGION=us-east-1

# Pilot workspace assigned to newly registered users (API POST /v1/auth/provision)
PILOT_WORKSPACE_ID=ws_e2e

# Frontend (build-time; see Dockerfile.web / deploy workflow)
# NEXT_PUBLIC_COGNITO_USER_POOL_ID=
# NEXT_PUBLIC_COGNITO_CLIENT_ID=
# NEXT_PUBLIC_COGNITO_DOMAIN=reelify-auth.auth.us-east-1.amazoncognito.com
