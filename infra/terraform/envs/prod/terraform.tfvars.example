# Copy to terraform.tfvars (gitignored) and adjust. All values are the built-in
# defaults; override only what you need across the phased apply.

project           = "reelify"
env               = "prod"
aws_region        = "us-east-1"
data_region       = "us"
media_bucket_name = "reelify-media-us"
db_instance_class = "db.t4g.micro"
domain            = "reelify.cc"

# Phase toggles (flip as you progress — see README):
# backend_image      = "666730152143.dkr.ecr.us-east-1.amazonaws.com/reelify/backend:latest"
# web_image          = "666730152143.dkr.ecr.us-east-1.amazonaws.com/reelify/web:latest"
# create_certificate = true
# enable_dns_records = true
# auth_mode          = "cognito"
